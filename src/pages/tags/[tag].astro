---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { filterPublished } from '../../lib/date-filter'

export async function getStaticPaths() {
  const allDaily = filterPublished(await getCollection('daily'))
  const allDeepDive = filterPublished(await getCollection('deep-dive'))
  const allTips = filterPublished(await getCollection('tips'))

  const tagMap = new Map<string, { slug: string; title: string; date: string; collection: string }[]>()

  for (const article of allDaily) {
    for (const tag of article.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, [])
      tagMap.get(tag)!.push({ slug: article.slug, title: article.data.title, date: article.data.date, collection: 'daily' })
    }
  }
  for (const article of allDeepDive) {
    for (const tag of article.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, [])
      tagMap.get(tag)!.push({ slug: article.slug, title: article.data.title, date: article.data.date, collection: 'deep-dive' })
    }
  }
  for (const article of allTips) {
    for (const tag of article.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, [])
      tagMap.get(tag)!.push({ slug: article.slug, title: article.data.title, date: article.data.date, collection: 'tips' })
    }
  }

  return Array.from(tagMap.entries()).map(([tag, articles]) => ({
    params: { tag },
    props: {
      tag,
      articles: articles.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()),
    },
  }))
}

const { tag, articles } = Astro.props

const collectionLabels: Record<string, string> = {
  daily: 'ニュース',
  'deep-dive': '深掘り解説',
  tips: 'AI活用Tips',
}

const collectionPaths: Record<string, string> = {
  daily: '/daily',
  'deep-dive': '/deep-dive',
  tips: '/tips',
}
---

<BaseLayout
  title={`「${tag}」の記事一覧`}
  description={`Kaikei AI Dailyの「${tag}」タグが付いた記事一覧。${articles.length}件の記事があります。`}
  noindex={true}
>
  <div class="tag-archive">
    <nav class="breadcrumbs" aria-label="パンくずリスト">
      <a href="/">ホーム</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">タグ: {tag}</span>
    </nav>

    <header class="tag-header">
      <h1>
        <span class="tag-label">タグ</span>
        {tag}
      </h1>
      <p class="tag-count">{articles.length}件の記事</p>
    </header>

    <ul class="article-list">
      {articles.map((article) => (
        <li>
          <a href={`${collectionPaths[article.collection]}/${article.slug}`} class="article-link">
            <time class="article-date">{article.date}</time>
            <span class="article-type">{collectionLabels[article.collection]}</span>
            <span class="article-title">{article.title}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="back-nav">
      <a href="/" class="btn btn-outline">ニュース一覧に戻る</a>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-archive { max-width: 720px; }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 1.5rem;
  }
  .breadcrumbs a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .breadcrumbs a:hover { text-decoration: underline; }

  .tag-header {
    margin-bottom: 2rem;
  }

  .tag-header h1 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .tag-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    background: var(--color-primary);
    color: white;
    border: 2px solid var(--color-outline);
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  .tag-count {
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-list li {
    border-bottom: 1px solid var(--color-border, #e0e0e0);
  }

  .article-link {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem 0.5rem;
    text-decoration: none;
    color: var(--color-on-surface);
    transition: background 0.15s;
    min-height: 44px;
  }

  .article-link:hover {
    background: var(--color-surface-variant);
  }

  .article-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-on-surface-variant);
    white-space: nowrap;
  }

  .article-type {
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.125rem 0.375rem;
    background: var(--color-surface-variant);
    border: 1px solid var(--color-border, #e0e0e0);
    color: var(--color-on-surface-variant);
    white-space: nowrap;
  }

  .article-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .back-nav {
    margin-top: 2rem;
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    border: 3px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-outline);
    transition: transform 0.15s, box-shadow 0.15s;
    min-height: 44px;
  }

  .btn-outline {
    background: var(--color-surface);
    color: var(--color-on-surface);
  }

  .btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-outline);
  }

  @media (max-width: 640px) {
    .article-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
    .article-date, .article-type {
      display: inline-block;
    }
  }
</style>
