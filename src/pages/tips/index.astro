---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { filterPublished } from '../../lib/date-filter'
import { SUPERVISOR_LABEL } from '../../constants/site'

const allTips = filterPublished(await getCollection('tips'))
const tips = allTips
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
---

<BaseLayout title="AI活用Tips" description="経理実務で今日から使えるAI活用Tips。ChatGPT、Claude等のプロンプトやワークフローを紹介します。">

  <section class="section-header">
    <div class="section-header-inner">
      <div class="section-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </div>
      <div>
        <h1>AI活用Tips</h1>
        <p>経理実務で今日から使えるAI活用のプロンプトやワークフローを紹介します。</p>
      </div>
    </div>
  </section>

  <!-- BOOTH プロモ（P2: 若手会計士向け） -->
  <aside class="booth-banner" aria-label="おすすめプロダクト">
    <div class="booth-banner-inner">
      <div class="booth-banner-text">
        <p class="booth-banner-label">
          <span class="ad-mark">PR</span> Tipsをすぐ実践したい方へ
        </p>
        <p class="booth-banner-title">経理AIプロンプト集 -- {SUPERVISOR_LABEL}・即使える実務パック</p>
      </div>
      <a href="https://ezark.booth.pm" target="_blank" rel="noopener sponsored" class="booth-btn">
        BOOTHで購入
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>
  </aside>

  <div class="tips-list">
    {tips.map((tip) => (
      <article class="tip-card">
        <div class="tip-meta">
          <time class="tip-date" datetime={tip.data.date}>{tip.data.date}</time>
          {tip.data.tool && <span class="tool-badge">{tip.data.tool}</span>}
        </div>
        <h2 class="tip-title">
          <a href={`/tips/${tip.slug}`}>{tip.data.title}</a>
        </h2>
        <p class="tip-summary">{tip.data.summary}</p>
        <div class="tip-tags">
          {tip.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <a href={`/tips/${tip.slug}`} class="read-more" aria-label={`${tip.data.title} を読む`}>
          続きを読む
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </article>
    ))}
  </div>

</BaseLayout>

<style>
  /* ── Section Header ── */
  .section-header { margin-bottom: 1.5rem; }

  .section-header-inner {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .section-icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--color-outline);
  }

  .section-header h1 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.25rem; }
  .section-header p { color: var(--color-on-surface-variant); font-size: 0.9375rem; }

  /* ── BOOTH Banner ── */
  .booth-banner {
    border: 4px solid var(--color-outline);
    box-shadow: 6px 6px 0 var(--color-shadow);
    background: var(--color-surface);
    margin-bottom: 2rem;
  }

  .booth-banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .booth-banner-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .ad-mark {
    font-size: 0.5625rem;
    background: var(--color-border);
    color: var(--color-on-surface-variant);
    padding: 0 0.25rem;
    margin-right: 0.25rem;
    vertical-align: middle;
  }

  .booth-banner-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .booth-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 700;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border: 3px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-outline);
    transition: transform 0.1s, box-shadow 0.1s;
    white-space: nowrap;
  }

  .booth-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-outline);
  }

  /* ── Tips List ── */
  .tips-list { display: flex; flex-direction: column; gap: 1rem; }

  /* ── Tip Card (Neo-Brutalism) ── */
  .tip-card {
    background: var(--color-surface);
    border: 4px solid var(--color-outline);
    box-shadow: 8px 8px 0 var(--color-shadow);
    padding: 1.25rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .tip-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0 var(--color-shadow);
  }

  .tip-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .tip-date { font-size: 0.75rem; color: var(--color-on-surface-variant); font-family: var(--font-mono); }
  .tool-badge {
    font-size: 0.6875rem;
    font-weight: 700;
    background: var(--color-on-surface);
    color: white;
    padding: 0.1rem 0.4rem;
  }

  .tip-title { font-size: 1.0625rem; font-weight: 700; margin-bottom: 0.5rem; }
  .tip-title a { color: var(--color-on-surface); text-decoration: none; }
  .tip-title a:hover { color: var(--color-primary); }

  .tip-summary { font-size: 0.875rem; color: var(--color-on-surface-variant); line-height: 1.6; }

  .tip-tags { display: flex; gap: 0.375rem; margin-top: 0.75rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-surface-variant);
    border: 1px solid var(--color-border);
    color: var(--color-on-surface-variant);
    font-weight: 500;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .read-more:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .booth-banner-inner { flex-direction: column; align-items: flex-start; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tip-card, .booth-btn { transition: none; }
  }
</style>
