---
import BaseLayout from '../../layouts/BaseLayout.astro'
import NewsletterCTA from '../../components/NewsletterCTA.astro'
import NoteDeepDiveLink from '../../components/NoteDeepDiveLink.astro'
import { getCollection } from 'astro:content'
import { filterPublished } from '../../lib/date-filter'
import { SUPERVISOR_LABEL } from '../../constants/site'
import AdUnit from '../../components/AdUnit.astro'
import { AD_CLIENT, AD_SLOTS } from '../../constants/ad-config'

export async function getStaticPaths() {
  const tips = filterPublished(await getCollection('tips'))
  return tips.map((tip) => ({
    params: { slug: tip.slug },
    props: { tip },
  }))
}

const { tip } = Astro.props
const { Content } = await tip.render()

const canonicalURL = new URL(`/tips/${tip.slug}/`, Astro.site)
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: tip.data.title,
  description: tip.data.summary,
  datePublished: `${tip.data.date}T09:00:00+09:00`,
  dateModified: `${tip.data.date}T09:00:00+09:00`,
  url: canonicalURL.href,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
  author: {
    '@type': 'Person',
    name: 'Kaikei AI Daily編集部',
    description: 'AI×会計の専門メディア。公認会計士試験合格者が監修。',
    url: 'https://kaikei-ai.jp/about',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: '公認会計士試験合格',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'Kaikei AI Daily',
    url: 'https://kaikei-ai.jp',
    logo: { '@type': 'ImageObject', url: 'https://kaikei-ai.jp/favicon.svg' },
  },
  image: new URL(`/og/tips/${tip.slug}.png`, Astro.site).toString(),
  inLanguage: 'ja',
  keywords: tip.data.tags?.join(', '),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Kaikei AI Daily', item: 'https://kaikei-ai.jp/' },
    { '@type': 'ListItem', position: 2, name: 'AI活用Tips', item: 'https://kaikei-ai.jp/tips/' },
    { '@type': 'ListItem', position: 3, name: tip.data.title },
  ],
}
---

<BaseLayout title={tip.data.title} description={tip.data.summary} ogImage={new URL(`/og/tips/${tip.slug}.png`, Astro.site).toString()} ogType="article" structuredData={articleSchema}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {AD_SLOTS.articleMid.slot && (
    <script is:inline define:vars={{ adClient: AD_CLIENT, adSlot: AD_SLOTS.articleMid.slot }}>
      window.__AD_SLOTS_articleMid = { client: adClient, slot: adSlot };
    </script>
  )}
  <article class="tip-article">
    <header>
      <a href="/tips" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        AI活用Tips一覧に戻る
      </a>
      <div class="tip-meta">
        <time class="tip-date" datetime={tip.data.date}>{tip.data.date}</time>
        {tip.data.tool && <span class="tool-badge">{tip.data.tool}</span>}
      </div>
      <h1>{tip.data.title}</h1>
      <p class="tip-summary">{tip.data.summary}</p>
      <div class="tip-tags">
        {tip.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <!-- 広告: 記事タイトル直下 -->
    <AdUnit name="articleTop" />

    <div class="article-body" id="article-body">
      <Content />
    </div>

    <!-- 広告: 記事本文直後 -->
    <AdUnit name="articleBottom" />

    <!-- BOOTH: 会計×AIプロンプト集プロモ（P2: 若手会計士向け） -->
    <aside class="booth-promo" aria-label="関連プロダクト">
      <div class="booth-promo-inner">
        <div class="booth-promo-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div class="booth-promo-content">
          <p class="booth-promo-label">
            <span class="ad-mark">PR</span> 会計士・経理担当者向けプロンプト集
          </p>
          <p class="booth-promo-title">AI会計プロンプト実務パック</p>
          <p class="booth-promo-desc">月次決算・税務申告・監査対応をAIでスピードアップ。現役{SUPERVISOR_LABEL}の即使えるプロンプト集。</p>
          <a
            href="https://ezark.booth.pm"
            target="_blank"
            rel="noopener sponsored"
            class="btn btn-booth"
          >
            BOOTHで見る
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </div>
    </aside>

    <!-- 広告: マルチプレックス -->
    <AdUnit name="articleMultiplex" />

    <!-- note深掘り記事クロスリンク（タグ連動型） -->
    <NoteDeepDiveLink tags={tip.data.tags} title={tip.data.title} articleType="tips" />

    <!-- 関連サービスCTA -->
    <aside class="related-services" aria-label="関連サービス">
      <h3 class="related-services-title">もっと深く学ぶ</h3>
      <div class="related-services-grid">
        <a href="https://ezark-tax-accounting.com/" target="_blank" rel="noopener noreferrer" class="service-link">
          <span class="service-label">EZARK Blog</span>
          <span class="service-desc">AI×税務・会計の詳細ガイド</span>
        </a>
        <a href="https://note.com/ezark_company" target="_blank" rel="noopener noreferrer" class="service-link">
          <span class="service-label">note</span>
          <span class="service-desc">AI×会計の深掘りテクニック</span>
        </a>
        <a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener noreferrer" class="service-link">
          <span class="service-label">BOOTH</span>
          <span class="service-desc">経理AIプロンプト集・テンプレート</span>
        </a>
      </div>
    </aside>

    <!-- Newsletter CTA -->
    <NewsletterCTA variant="compact" />

    <div class="article-cta">
      <p>もっとAI活用Tipsを受け取る</p>
      <a href="https://x.com/kaikeiAI_Lab" target="_blank" rel="noopener" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X でフォロー
      </a>
    </div>
  </article>

  <script>
    // 記事内広告: h2の2つ目の前に自動挿入
    (function() {
      const body = document.getElementById('article-body');
      if (!body) return;
      const h2s = body.querySelectorAll('h2');
      if (h2s.length < 2) return;
      const target = h2s[1];
      const adConfig = window.__AD_SLOTS_articleMid;
      if (!adConfig) return;
      const wrapper = document.createElement('aside');
      wrapper.className = 'ad-unit ad-unit--articleMid';
      wrapper.setAttribute('aria-label', '広告');
      const label = document.createElement('span');
      label.className = 'ad-unit__label';
      label.textContent = '広告';
      wrapper.appendChild(label);
      const ins = document.createElement('ins');
      ins.className = 'adsbygoogle';
      ins.style.cssText = 'display:block; text-align:center;';
      ins.dataset.adClient = adConfig.client;
      ins.dataset.adSlot = adConfig.slot;
      ins.dataset.adFormat = 'fluid';
      ins.dataset.adLayout = 'in-article';
      wrapper.appendChild(ins);
      target.parentNode.insertBefore(wrapper, target);
      try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
    })();
  </script>

  <script>
    document.querySelectorAll('a[rel*="sponsored"]').forEach(link => {
      link.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'affiliate_click', {
            event_category: 'monetization',
            event_label: link.textContent?.trim() ?? '',
            transport_type: 'beacon',
          });
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .tip-article { max-width: 720px; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .back-link:hover { color: var(--color-primary); }

  .tip-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .tip-date { font-size: 0.75rem; color: var(--color-on-surface-variant); font-family: var(--font-mono); }
  .tool-badge { font-size: 0.6875rem; font-weight: 700; background: var(--color-on-surface); color: white; padding: 0.15rem 0.5rem; }

  header h1 { font-size: 1.75rem; font-weight: 800; margin: 0.5rem 0; line-height: 1.4; }
  .tip-summary { font-size: 1rem; color: var(--color-on-surface-variant); line-height: 1.7; margin-bottom: 0.75rem; }
  .tip-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .tag { font-size: 0.6875rem; padding: 0.125rem 0.5rem; background: var(--color-surface-variant); border: 1px solid var(--color-border); color: var(--color-on-surface-variant); font-weight: 500; }

  /* ── Article Body ── */
  .article-body { font-size: 0.9375rem; line-height: 1.85; }
  .article-body :global(h2) { font-size: 1.25rem; font-weight: 700; margin: 2rem 0 0.75rem; padding-bottom: 0.5rem; border-bottom: 4px solid var(--color-border); }
  .article-body :global(h3) { font-size: 1.0625rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .article-body :global(p) { margin-bottom: 1rem; }
  .article-body :global(ul), .article-body :global(ol) { margin: 0.5rem 0 1rem 1.25rem; }
  .article-body :global(li) { margin-bottom: 0.25rem; }
  .article-body :global(pre) { background: var(--color-surface); border: 4px solid var(--color-border); padding: 1rem; overflow-x: auto; margin: 1rem 0; font-size: 0.8125rem; }
  .article-body :global(code) { font-family: var(--font-mono); font-size: 0.85em; }
  .article-body :global(table) { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.875rem; }
  .article-body :global(th), .article-body :global(td) { border: 1px solid var(--color-border); padding: 0.5rem; text-align: left; }
  .article-body :global(th) { background: var(--color-surface-variant); font-weight: 600; }

  /* ── BOOTH Promo (Neo-Brutalism) ── */
  .booth-promo {
    margin-top: 2.5rem;
    border: 4px solid var(--color-outline);
    box-shadow: 6px 6px 0 var(--color-shadow);
    background: var(--color-surface);
  }

  .booth-promo-inner {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
  }

  .booth-promo-icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .booth-promo-content { flex: 1; }

  .booth-promo-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ad-mark {
    font-size: 0.5625rem;
    background: var(--color-border);
    color: var(--color-on-surface-variant);
    padding: 0 0.25rem;
    margin-right: 0.25rem;
    vertical-align: middle;
  }

  .booth-promo-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.375rem;
    color: var(--color-on-surface);
  }

  .booth-promo-desc {
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  /* ── CTA ── */
  .article-cta {
    text-align: center;
    padding: 2.5rem 0;
    margin-top: 2rem;
    border-top: 4px solid var(--color-on-surface);
  }
  .article-cta p { font-size: 0.9375rem; color: var(--color-on-surface-variant); margin-bottom: 1rem; }

  /* ── Buttons (Neo-Brutalism) ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    border: 3px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-outline);
    transition: transform 0.1s, box-shadow 0.1s;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-outline);
  }

  .btn-booth {
    background: var(--color-accent);
    color: white;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
  }

  .btn-booth:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-outline);
  }

  /* ── 関連サービスCTA ── */
  .related-services {
    margin-top: 2rem;
    margin-bottom: 1.5rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 3px solid var(--color-border);
  }

  .related-services-title {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-on-surface);
  }

  .related-services-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    background: var(--color-surface-variant);
    border: 2px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.15s;
    min-height: 44px;
  }

  .service-link:hover {
    border-color: var(--color-primary);
  }

  .service-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
    min-width: 5rem;
  }

  .service-desc {
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
  }

  @media (max-width: 640px) {
    .booth-promo-inner { flex-direction: column; }
    .booth-promo-icon { width: 2rem; height: 2rem; }
  }

  @media (min-width: 640px) {
    .related-services-grid {
      flex-direction: row;
    }
    .service-link {
      flex: 1;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
    .service-label { min-width: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn { transition: none; }
  }
</style>
