---
import BaseLayout from '../../layouts/BaseLayout.astro'
import NewsletterCTA from '../../components/NewsletterCTA.astro'
import NoteDeepDiveLink from '../../components/NoteDeepDiveLink.astro'
import ShareButtons from '../../components/ShareButtons.astro'
import AdUnit from '../../components/AdUnit.astro'
import { getCollection } from 'astro:content'
import { filterPublished } from '../../lib/date-filter'
import { AD_CLIENT, AD_SLOTS } from '../../constants/ad-config'

export async function getStaticPaths() {
  const articles = filterPublished(await getCollection('daily'))
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await article.render()

// All daily articles should be indexed for long-tail SEO value.
// Previous 30-day noindex was causing sitemap/noindex conflict and
// blocking 70%+ of content from Google's index (P0 fix 2026-03-22).
const shouldNoindex = false

// 前後記事のナビゲーション
const allArticles = filterPublished(await getCollection('daily')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
const currentIndex = allArticles.findIndex((a) => a.slug === article.slug)
const prevArticle = currentIndex < allArticles.length - 1 ? allArticles[currentIndex + 1] : null
const nextArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : null

const canonicalURL = new URL(`/daily/${article.slug}/`, Astro.site)
const newsArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: article.data.title,
  description: article.data.summary,
  datePublished: `${article.data.date}T05:30:00+09:00`,
  dateModified: `${article.data.date}T05:30:00+09:00`,
  url: canonicalURL.href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL.href,
  },
  author: {
    '@type': 'Person',
    name: 'Kaikei AI Daily編集部',
    description: 'AI×会計の専門メディア。公認会計士試験合格者が監修。',
    url: 'https://kaikei-ai.jp/about',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: '公認会計士試験合格',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'Kaikei AI Daily',
    url: 'https://kaikei-ai.jp',
    logo: {
      '@type': 'ImageObject',
      url: 'https://kaikei-ai.jp/favicon.svg',
    },
  },
  inLanguage: 'ja',
  keywords: article.data.tags?.join(', '),
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Kaikei AI Daily', item: 'https://kaikei-ai.jp/' },
    { '@type': 'ListItem', position: 2, name: 'ニュース一覧', item: 'https://kaikei-ai.jp/' },
    { '@type': 'ListItem', position: 3, name: article.data.title },
  ],
}
---

<BaseLayout
  title={article.data.title}
  description={article.data.summary}
  ogImage={new URL('/og/daily.png', Astro.site).toString()}
  ogType="article"
  structuredData={newsArticleSchema}
  noindex={shouldNoindex}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {AD_SLOTS.articleMid.slot && (
    <script is:inline define:vars={{ adClient: AD_CLIENT, adSlot: AD_SLOTS.articleMid.slot }}>
      window.__AD_SLOTS_articleMid = { client: adClient, slot: adSlot };
    </script>
  )}
  <article class="daily-article">
    <header class="article-header">
      <a href="/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        ニュース一覧に戻る
      </a>

      <div class="article-eyebrow">
        <time class="article-date" datetime={article.data.date}>{article.data.date}</time>
        <div class="article-badges">
          <span class="badge badge--cpa">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            CPA試験合格者監修
          </span>
          <span class="badge badge--time">約3分で読めます</span>
        </div>
      </div>

      <h1>{article.data.title}</h1>
      <p class="article-summary">{article.data.summary}</p>
      <div class="article-tags">
        {article.data.tags.map((tag) => (
          <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>
        ))}
      </div>

      <ShareButtons title={article.data.title} url={canonicalURL.href} />
    </header>

    <!-- 広告: 記事タイトル直下 -->
    <AdUnit name="articleTop" />

    <!-- 経理プロ向け: 記事本文 -->
    <div class="article-body" id="article-body">
      <Content />
    </div>

    <!-- 広告: 記事本文直後 -->
    <AdUnit name="articleBottom" />

    <!-- ソース情報 -->
    {article.data.sources && article.data.sources.length > 0 && (
      <aside class="article-sources">
        <h3>情報ソース</h3>
        <ul>
          {article.data.sources.map((source) => (
            <li>
              {source.url ? (
                <a href={source.url} target="_blank" rel="noopener">{source.name}</a>
              ) : (
                source.name
              )}
            </li>
          ))}
        </ul>
      </aside>
    )}

    <!-- 前後記事ナビゲーション -->
    <nav class="article-nav" aria-label="前後の記事">
      <div class="article-nav-inner">
        {prevArticle ? (
          <a href={`/daily/${prevArticle.slug}`} class="article-nav-link article-nav-link--prev">
            <span class="article-nav-label">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              前の記事
            </span>
            <span class="article-nav-title">{prevArticle.data.title}</span>
          </a>
        ) : (
          <div></div>
        )}
        {nextArticle ? (
          <a href={`/daily/${nextArticle.slug}`} class="article-nav-link article-nav-link--next">
            <span class="article-nav-label">
              次の記事
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
            <span class="article-nav-title">{nextArticle.data.title}</span>
          </a>
        ) : (
          <div></div>
        )}
      </div>
    </nav>

    <!-- 広告: マルチプレックス（関連コンテンツ風） -->
    <AdUnit name="articleMultiplex" />

    <!-- note深掘り記事クロスリンク（タグ連動型） -->
    <NoteDeepDiveLink tags={article.data.tags} title={article.data.title} articleType="daily" />

    <!-- 関連サービスCTA -->
    <aside class="related-services" aria-label="関連サービス">
      <h3 class="related-services-title">もっと深く学ぶ</h3>
      <div class="related-services-grid">
        <a href="https://ezark-tax-accounting.com/" target="_blank" rel="noopener noreferrer" class="service-link">
          <span class="service-label">EZARK Blog</span>
          <span class="service-desc">AI×税務・会計の詳細ガイド</span>
        </a>
        <a href="https://note.com/ezark_company" target="_blank" rel="noopener noreferrer" class="service-link">
          <span class="service-label">note</span>
          <span class="service-desc">AI×会計の深掘りテクニック</span>
        </a>
        <a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener noreferrer" class="service-link">
          <span class="service-label">BOOTH</span>
          <span class="service-desc">経理AIプロンプト集・テンプレート</span>
        </a>
      </div>
    </aside>

    <!-- Newsletter CTA -->
    <NewsletterCTA variant="compact" />

    <!-- CTA: ペルソナ別訴求 -->
    <div class="article-cta">
      <div class="article-cta-inner">
        <h2>会計×AIをもっと活用する</h2>
        <p>毎朝7時にX(@KaikeiAI_Lab)でAI会計ニュース速報配信中。<br />実務で使えるAIプロンプト集はBOOTHで配布中（無料サンプルあり）。</p>
        <div class="cta-links">
          <a href="https://x.com/KaikeiAI_Lab" target="_blank" rel="noopener" class="btn btn-primary">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X でフォロー
          </a>
          <a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener" class="btn btn-outline">
            AIプロンプト集 (BOOTH)
          </a>
          <a href="/" class="btn btn-outline">ニュース一覧へ</a>
        </div>
      </div>
    </div>
  </article>

  <script>
    // 記事内広告: h2の2つ目の前に自動挿入（モバイルでは最大2広告に制限）
    (function() {
      const body = document.getElementById('article-body');
      if (!body) return;
      const h2s = body.querySelectorAll('h2');
      if (h2s.length < 2) return;

      const target = h2s[1]; // 2つ目のh2
      const adConfig = window.__AD_SLOTS_articleMid;
      if (!adConfig) return;

      const wrapper = document.createElement('aside');
      wrapper.className = 'ad-unit ad-unit--articleMid';
      wrapper.setAttribute('aria-label', '広告');

      const label = document.createElement('span');
      label.className = 'ad-unit__label';
      label.textContent = '広告';
      wrapper.appendChild(label);

      const ins = document.createElement('ins');
      ins.className = 'adsbygoogle';
      ins.style.cssText = 'display:block; text-align:center;';
      ins.dataset.adClient = adConfig.client;
      ins.dataset.adSlot = adConfig.slot;
      ins.dataset.adFormat = 'fluid';
      ins.dataset.adLayout = 'in-article';
      wrapper.appendChild(ins);

      target.parentNode.insertBefore(wrapper, target);

      try {
        (adsbygoogle = window.adsbygoogle || []).push({});
      } catch(e) {}
    })();
  </script>

  <script>
    document.querySelectorAll('a[rel*="sponsored"]').forEach(link => {
      link.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'affiliate_click', {
            event_category: 'monetization',
            event_label: link.textContent?.trim() ?? '',
            transport_type: 'beacon',
          });
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .daily-article { max-width: 720px; }

  /* ── Back link ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
    text-decoration: none;
    margin-bottom: 1.25rem;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--color-primary); }

  /* ── Header ── */
  .article-header { margin-bottom: 2rem; }

  .article-eyebrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-size: 0.75rem;
    color: var(--color-on-surface-variant);
    font-family: var(--font-mono);
  }

  .article-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.03em;
    border: 3px solid var(--color-outline);
    box-shadow: 2px 2px 0 var(--color-shadow);
  }

  .badge--cpa {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-outline);
  }

  .badge--time {
    background: var(--color-surface-variant);
    color: var(--color-on-surface-variant);
    border-color: var(--color-border);
    font-weight: 500;
  }

  .article-header h1 {
    font-size: clamp(1.375rem, 3.5vw, 2rem);
    font-weight: 800;
    margin: 0 0 0.75rem;
    line-height: 1.4;
    letter-spacing: -0.02em;
  }

  .article-summary {
    font-size: 1rem;
    color: var(--color-on-surface-variant);
    line-height: 1.75;
    margin-bottom: 0.875rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border-left: 4px solid var(--color-primary);
  }

  .article-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; }

  .tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-surface-variant);
    border: 2px solid var(--color-outline);
    color: var(--color-on-surface-variant);
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .tag:hover {
    background: var(--color-primary);
    color: white;
  }

  /* ── Article Body ── */
  .article-body {
    font-size: 0.9375rem;
    line-height: 1.9;
    color: var(--color-on-surface);
    margin-bottom: 2rem;
  }

  .article-body :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 2.25rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid var(--color-outline);
  }

  .article-body :global(h3) {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 1.75rem 0 0.5rem;
    padding-left: 0.625rem;
    border-left: 4px solid var(--color-primary);
  }

  .article-body :global(p) { margin-bottom: 1rem; }

  .article-body :global(ul), .article-body :global(ol) {
    margin: 0.5rem 0 1rem 1.375rem;
  }

  .article-body :global(li) { margin-bottom: 0.375rem; }

  .article-body :global(hr) {
    border: none;
    border-top: 3px solid var(--color-border);
    margin: 2rem 0;
  }

  .article-body :global(strong) { color: var(--color-on-surface); }

  .article-body :global(a) { color: var(--color-primary); }
  .article-body :global(a:hover) { text-decoration: underline; }

  /* ── Sources ── */
  .article-sources {
    background: var(--color-surface);
    border: 4px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-shadow);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
  }

  .article-sources h3 {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .article-sources ul { list-style: none; }
  .article-sources li {
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.25rem;
  }
  .article-sources a { color: var(--color-primary); text-decoration: none; }
  .article-sources a:hover { text-decoration: underline; }

  /* ── 前後ナビ ── */
  .article-nav {
    margin-bottom: 2rem;
    border-top: 3px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .article-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .article-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.875rem;
    background: var(--color-surface);
    border: 3px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-shadow);
    text-decoration: none;
    color: var(--color-on-surface);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .article-nav-link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-shadow);
  }

  .article-nav-link--next {
    text-align: right;
  }

  .article-nav-label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-on-surface-variant);
    letter-spacing: 0.04em;
  }

  .article-nav-link--next .article-nav-label { justify-content: flex-end; }

  .article-nav-title {
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--color-on-surface);
  }

  /* ── CTA ── */
  .article-cta {
    border-top: 4px solid var(--color-outline);
    padding: 2rem 0;
  }

  .article-cta-inner { text-align: center; }

  .article-cta h2 { font-size: 1.25rem; font-weight: 800; margin-bottom: 0.5rem; }

  .article-cta p {
    font-size: 0.9375rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .cta-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    border: 3px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-outline);
    transition: transform 0.15s, box-shadow 0.15s;
    cursor: pointer;
    min-height: 44px;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }

  .btn-outline {
    background: var(--color-surface);
    color: var(--color-on-surface);
  }

  .btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-outline);
  }

  /* ── 関連サービスCTA ── */
  .related-services {
    margin-bottom: 1.5rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 3px solid var(--color-border);
  }

  .related-services-title {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-on-surface);
  }

  .related-services-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    background: var(--color-surface-variant);
    border: 2px solid var(--color-border);
    text-decoration: none;
    transition: border-color 0.15s;
    min-height: 44px;
  }

  .service-link:hover {
    border-color: var(--color-primary);
  }

  .service-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
    min-width: 5rem;
  }

  .service-desc {
    font-size: 0.8125rem;
    color: var(--color-on-surface-variant);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .article-eyebrow { flex-direction: column; align-items: flex-start; gap: 0.375rem; }
    .article-nav-inner { grid-template-columns: 1fr; }
    .cta-links { flex-direction: column; align-items: center; }
  }

  @media (min-width: 640px) {
    .related-services-grid {
      flex-direction: row;
    }
    .service-link {
      flex: 1;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
    .service-label { min-width: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn, .article-nav-link { transition: none; }
  }
</style>
