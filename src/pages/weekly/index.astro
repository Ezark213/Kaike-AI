---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { filterPublished } from '../../lib/date-filter'

const allArticles = filterPublished(await getCollection('weekly'))
const articles = allArticles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
---

<BaseLayout title="週刊AI会計ダイジェスト" description="1週間のAI×会計ニュースを厳選5本にまとめ、CPA試験合格者が実務影響を分析します。毎週月曜更新。">

  <section class="section-header">
    <div class="section-header-inner">
      <div class="section-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </div>
      <div>
        <h1>週刊AI会計ダイジェスト</h1>
        <p>1週間のAI×会計ニュースを厳選してまとめ。毎週月曜更新、CPA試験合格者が実務影響を分析します。</p>
      </div>
    </div>
  </section>

  <div class="article-list">
    {articles.map((article) => (
      <article class="article-card">
        <div class="article-meta">
          <time class="article-date">{article.data.weekStart} 〜 {article.data.weekEnd}</time>
          <span class="category-badge">週刊</span>
        </div>
        <h2 class="article-title">
          <a href={`/weekly/${article.slug}`}>{article.data.title}</a>
        </h2>
        <p class="article-summary">{article.data.summary}</p>
        <div class="article-tags">
          {article.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <a href={`/weekly/${article.slug}`} class="read-more" aria-label={`${article.data.title} を読む`}>
          ダイジェストを読む
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </article>
    ))}
  </div>

</BaseLayout>

<style>
  .section-header { margin-bottom: 2rem; }

  .section-header-inner {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .section-icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--color-outline);
  }

  .section-header h1 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.25rem; }
  .section-header p { color: var(--color-on-surface-variant); font-size: 0.9375rem; }

  .article-list { display: flex; flex-direction: column; gap: 1rem; }

  .article-card {
    background: var(--color-surface);
    border: 4px solid var(--color-outline);
    box-shadow: 8px 8px 0 var(--color-shadow);
    padding: 1.25rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .article-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0 var(--color-shadow);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .article-date { font-size: 0.75rem; color: var(--color-on-surface-variant); font-family: var(--font-mono); }

  .category-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    background: var(--color-primary);
    color: white;
    padding: 0.1rem 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .article-title { font-size: 1.0625rem; font-weight: 700; margin: 0 0 0.5rem; }
  .article-title a { color: var(--color-on-surface); text-decoration: none; }
  .article-title a:hover { color: var(--color-primary); }

  .article-summary { font-size: 0.875rem; color: var(--color-on-surface-variant); line-height: 1.6; }

  .article-tags { display: flex; gap: 0.375rem; margin-top: 0.75rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: var(--color-surface-variant);
    border: 1px solid var(--color-border);
    color: var(--color-on-surface-variant);
    font-weight: 500;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .read-more:hover { text-decoration: underline; }

  @media (prefers-reduced-motion: reduce) {
    .article-card { transition: none; }
  }
</style>
