---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getCollection } from "astro:content"
import { filterPublished } from "../../lib/date-filter"

const allDeepDive = filterPublished(await getCollection("deep-dive"))
const cfoTags = ["経営指標", "財務分析", "管理会計", "KPI", "損益分岐点", "予算", "事業計画", "キャッシュフロー", "経営管理", "意思決定", "CVP分析"]
const deepDives = allDeepDive
  .filter(a => a.data.tags.some(t => cfoTags.includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())

const recommended = [
  { slug: "ai-zaimu-bunseki-2026", title: "AI×財務諸表分析 — 経営判断を加速" },
  { slug: "chatgpt-yosan-sakusei-2026", title: "ChatGPT×予算作成の自動化" },
  { slug: "ai-keiei-kanri-kaikei-2026", title: "AI×管理会計 — KPI・CVP分析" },
  { slug: "ai-cashflow-management-2026", title: "AI×資金繰り管理" },
  { slug: "ai-keiei-bunseki-chusho-2026", title: "AI経営分析で利益率を改善" },
]
---
<BaseLayout title="CFO・経営企画のためのAI活用ガイド" description="CFO・経営企画担当者向け。AI×財務分析、予算作成の自動化、管理会計のKPIダッシュボード、損益分岐点分析まで。データドリブンな経営判断を支援する実践情報をCPA試験合格者が監修。">
  <main id="main-content" class="persona-page">
    <section class="persona-hero cfo-hero">
      <div class="persona-hero-inner">
        <span class="persona-badge">CFO・経営企画向け</span>
        <h1>データドリブンな経営判断をAIで加速</h1>
        <p>財務分析の自動化、予算策定の効率化、KPIダッシュボードの構築。<br/>経営の意思決定を支えるAI活用ガイド。</p>
      </div>
    </section>
    <section class="recommended-section">
      <h2>まず読んでほしい記事</h2>
      <div class="recommended-grid">
        {recommended.map(r => (
          <a href={`/deep-dive/${r.slug}/`} class="recommended-card">
            <span class="recommended-title">{r.title}</span>
            <span class="recommended-arrow">→</span>
          </a>
        ))}
      </div>
    </section>
    <section class="articles-section">
      <h2>深掘り解説（{deepDives.length}本）</h2>
      <div class="articles-list">
        {deepDives.map(article => (
          <article class="article-card">
            <time datetime={article.data.date}>{article.data.date}</time>
            <h3><a href={`/deep-dive/${article.slug}/`}>{article.data.title}</a></h3>
            <p>{article.data.summary.substring(0, 100)}...</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
<style>
  .persona-page { max-width: 900px; margin: 0 auto; padding: 0 1rem; }
  .cfo-hero { background: linear-gradient(135deg, #212121, #424242); color: white; padding: 3rem 2rem; border-radius: 12px; margin: 2rem 0; }
  .persona-hero-inner { max-width: 700px; }
  .persona-badge { background: rgba(255,255,255,0.2); padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem; }
  .cfo-hero h1 { font-size: 2rem; margin: 1rem 0 0.5rem; }
  .cfo-hero p { opacity: 0.9; line-height: 1.8; }
  .recommended-section { margin: 2rem 0; }
  .recommended-section h2 { font-size: 1.3rem; margin-bottom: 1rem; }
  .recommended-grid { display: grid; gap: 0.75rem; }
  .recommended-card { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; background: var(--color-surface-variant, #f4f6f9); border: 2px solid var(--color-outline, #d1d5db); border-radius: 8px; text-decoration: none; color: inherit; transition: transform 0.15s; }
  .recommended-card:hover { transform: translateX(4px); border-color: var(--color-primary, #0066cc); }
  .recommended-title { font-weight: 600; }
  .recommended-arrow { font-size: 1.2rem; color: var(--color-primary, #0066cc); }
  .articles-section { margin: 3rem 0; }
  .articles-section h2 { font-size: 1.3rem; margin-bottom: 1rem; border-bottom: 2px solid var(--color-outline, #d1d5db); padding-bottom: 0.5rem; }
  .articles-list { display: grid; gap: 1rem; }
  .article-card { padding: 1rem; border: 1px solid var(--color-outline, #e5e7eb); border-radius: 8px; }
  .article-card time { font-size: 0.8rem; color: var(--color-on-surface-variant, #6b7280); }
  .article-card h3 { font-size: 1rem; margin: 0.25rem 0; }
  .article-card h3 a { text-decoration: none; color: inherit; }
  .article-card h3 a:hover { color: var(--color-primary, #0066cc); }
  .article-card p { font-size: 0.85rem; color: var(--color-on-surface-variant, #6b7280); margin: 0.25rem 0 0; }
</style>
