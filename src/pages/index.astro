---
import BaseLayout from '../layouts/BaseLayout.astro'
import NewsletterCTA from '../components/NewsletterCTA.astro'
import { getCollection } from 'astro:content'
import { filterPublished } from '../lib/date-filter'
import { SUPERVISOR_LABEL } from '../constants/site'
import AdUnit from '../components/AdUnit.astro'

const allArticles = filterPublished(await getCollection('daily'))
const articles = allArticles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 10)

const allWeekly = filterPublished(await getCollection('weekly'))
const weeklyArticles = allWeekly
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)

const latestTips = filterPublished(await getCollection('tips'))
const tips = latestTips
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2)

const todayArticle = articles[0]

// ペルソナ別: タグで最も関連する記事を取得
const keiriArticle = allArticles
  .filter(a => a.data.tags.some(t => ['経理DX','仕訳','経費精算','資金繰り','給与計算','業務効率化'].includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0]

const kaikeiShiArticle = allArticles
  .filter(a => a.data.tags.some(t => ['監査','IFRS','内部統制','会計士キャリア','Big4'].includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0]

const zeirishiArticle = allArticles
  .filter(a => a.data.tags.some(t => ['税務','税理士DX','節税','税務調査','インボイス'].includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0]

const cfoArticle = allArticles
  .filter(a => a.data.tags.some(t => ['CFO','経営分析','M&A','財務予測','KPI','ESG'].includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0]

// P3初心者向け: 入門系・基礎系記事を取得
const beginnerArticles = allArticles
  .filter(a => a.data.tags.some(t => ['業務効率化','経理DX','AI基礎','ChatGPT','freee','会計ソフト'].includes(t)))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3)

// WebSite JSON-LD構造化データ（トップページ用）
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Kaikei AI Daily',
  url: 'https://kaikei-ai.jp',
  description: 'AI会計ソフトの比較・レビュー、ChatGPT×経理の実践ガイド、AI監査・税務の最新ニュースを毎日配信。freee・マネーフォワード・弥生のAI機能をCPA試験合格者が徹底解説。',
  inLanguage: 'ja',
  publisher: {
    '@type': 'Organization',
    name: 'Kaikei AI Daily',
    url: 'https://kaikei-ai.jp',
    logo: {
      '@type': 'ImageObject',
      url: 'https://kaikei-ai.jp/favicon.svg',
    },
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://kaikei-ai.jp/search?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout title="AI会計ソフト比較・ChatGPT経理活用ガイド" structuredData={websiteSchema}>

  <!-- Hero: 経理マネージャー/CFO向け -- 毎朝5分ポジショニング -->
  <section class="hero">
    <div class="hero-eyebrow">
      <span class="hero-badge">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 13c0 5-3.5 7.5-8 8.5-4.5-1-8-3.5-8-8.5V6l8-3 8 3z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
        {SUPERVISOR_LABEL}
      </span>
      <span class="hero-badge hero-badge--auto">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
        </svg>
        毎朝5:30 自動更新
      </span>
    </div>
    <h1>
      忙しい経理・会計プロのための<br class="hero-br" />
      <em>AI会計ニュース</em>、毎朝配信
    </h1>
    <p class="hero-sub">
      経理マネージャー・公認会計士・税理士スタッフ向け。<br />
      AIによる自動収集・要約をベースに、CPA試験合格者が監修。実務に効くニュースだけをお届けします。
    </p>
    <div class="hero-cta">
      <a href="#latest" class="btn btn-primary">今日のニュースを見る</a>
      <a href="https://x.com/KaikeiAI_Lab" target="_blank" rel="noopener" class="btn btn-outline">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X でフォロー
      </a>
    </div>
    <div class="hero-stats" aria-label="サービス実績">
      <div class="stat"><strong>180+</strong><span>公開記事</span></div>
      <div class="stat-sep" aria-hidden="true">·</div>
      <div class="stat"><strong>毎朝</strong><span>5:30更新</span></div>
      <div class="stat-sep" aria-hidden="true">·</div>
      <div class="stat"><strong>全記事</strong><span>無料</span></div>
    </div>
  </section>

  <!-- Newsletter CTA: TOP PRIORITY -- 毎週のAI会計ニュースまとめ -->
  <NewsletterCTA variant="full" />

  <!-- ペルソナ別ナビ: 役割に合った情報へ誘導 (NEW) -->
  <section class="persona-nav" aria-label="役割別コンテンツガイド">
    <h2 class="persona-nav-title">あなたの役割に合った情報を</h2>
    <div class="persona-grid">
      <a href={keiriArticle ? `/daily/${keiriArticle.slug}` : '/'} class="persona-card">
        <div class="persona-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg></div>
        <h3>経理・財務担当</h3>
        <p>AI仕訳・自動化ツールの<br />実務導入情報</p>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
      <a href={kaikeiShiArticle ? `/daily/${kaikeiShiArticle.slug}` : '/'} class="persona-card persona-card--highlighted">
        <div class="persona-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="9" width="18" height="11"/><polyline points="3 9 12 2 21 9"/><line x1="3" y1="22" x2="21" y2="22"/><line x1="9" y1="22" x2="9" y2="13"/><line x1="15" y1="22" x2="15" y2="13"/></svg></div>
        <h3>公認会計士・監査法人</h3>
        <p>AI監査・DX動向・<br />キャリア差別化ヒント</p>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
      <a href={zeirishiArticle ? `/daily/${zeirishiArticle.slug}` : '/'} class="persona-card">
        <div class="persona-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></div>
        <h3>税理士・税務スタッフ</h3>
        <p>税務AI・顧客提案に使える<br />最新ネタ収集</p>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
      <a href={cfoArticle ? `/daily/${cfoArticle.slug}` : '/'} class="persona-card">
        <div class="persona-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
        <h3>経営企画・CFO</h3>
        <p>AI投資判断・競合動向・<br />戦略的インサイト</p>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- P3: はじめての方ガイド -- 若手税務スタッフ・初学者向け -->
  <section class="beginner-guide" aria-label="はじめての方へ">
    <div class="beginner-header">
      <h2>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
        </svg>
        はじめての方へ
      </h2>
      <p>会計×AIの世界へようこそ。まずはここから始めましょう。</p>
    </div>
    <div class="beginner-steps">
      <div class="beginner-step">
        <span class="step-number">1</span>
        <div class="step-content">
          <h3>毎朝チェック</h3>
          <p>このサイトは毎朝5:30に最新のAI×会計ニュースを自動配信。通勤中にスマホで3分読むだけで業界動向がわかります。</p>
        </div>
      </div>
      <div class="beginner-step">
        <span class="step-number">2</span>
        <div class="step-content">
          <h3>ツールを試す</h3>
          <p>freee会計やマネーフォワードなどのAI会計ソフトは無料トライアルで体験可能。まずは仕訳入力の自動化から始めましょう。</p>
        </div>
      </div>
      <div class="beginner-step">
        <span class="step-number">3</span>
        <div class="step-content">
          <h3>スキルアップ</h3>
          <p>AI活用Tipsで実務に使えるプロンプトを学び、BOOTHのテンプレートで効率化を加速させましょう。</p>
        </div>
      </div>
    </div>
    {beginnerArticles.length > 0 && (
      <div class="beginner-articles">
        <h3 class="beginner-articles-title">初心者におすすめの記事</h3>
        <div class="beginner-articles-list">
          {beginnerArticles.map((article) => (
            <a href={`/daily/${article.slug}`} class="beginner-article-link">
              <time>{article.data.date}</time>
              <span>{article.data.title}</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- 今日のトップニュース: CFO・経理マネ向けハイライト (NEW) -->
  {todayArticle && (
    <section class="today-highlight" aria-label="最新トップ記事">
      <div class="today-header">
        <div class="today-labels">
          <span class="today-badge">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
            </svg>
            最新
          </span>
          <span class="cpa-badge">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 13c0 5-3.5 7.5-8 8.5-4.5-1-8-3.5-8-8.5V6l8-3 8 3z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
            {SUPERVISOR_LABEL}
          </span>
        </div>
        <time class="today-date">{todayArticle.data.date}</time>
      </div>
      <h2 class="today-title">
        <a href={`/daily/${todayArticle.slug}`}>{todayArticle.data.title}</a>
      </h2>
      <p class="today-summary">{todayArticle.data.summary}</p>
      <div class="today-footer">
        <div class="today-tags">
          {todayArticle.data.tags.slice(0, 3).map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <a href={`/daily/${todayArticle.slug}`} class="btn btn-primary">
          全文を読む
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </section>
  )}

  <!-- アフィリエイト: 経理ソフト推薦 -- ペルソナターゲット (NEW) -->
  <aside class="affiliate-strip" aria-label="おすすめ経理ソフト（広告）">
    <p class="affiliate-label">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      AIで経理を効率化するならこちら（広告）
    </p>
    <div class="affiliate-links">
      <a href="https://px.a8.net/svt/ejp?a8mat=4AZ8K2+FBBEYA+3SPO+9FL80Y" target="_blank" rel="noopener sponsored" class="affiliate-btn affiliate-btn--primary">
        freee会計 — 無料で試す
      </a>
      <a href="https://px.a8.net/svt/ejp?a8mat=4AZ8K2+F5D2WI+4JGQ+60WN6" target="_blank" rel="noopener sponsored" class="affiliate-btn">
        マネーフォワード クラウド会計
      </a>
      <a href="https://px.a8.net/svt/ejp?a8mat=4AZ8K2+FCIA5U+4JGQ+BZ8OY" target="_blank" rel="noopener sponsored" class="affiliate-btn">
        MF 確定申告
      </a>
      <a href="https://px.a8.net/svt/ejp?a8mat=4AZ9C6+FBWUK2+48D0+6A4FM" target="_blank" rel="noopener sponsored" class="affiliate-btn">
        FXTF — 狭スプレッドFX取引
      </a>
    </div>
  </aside>

  <!-- Latest articles -->
  <section id="latest" class="latest-section">
    <div class="section-header">
      <h2>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
        </svg>
        ニュース一覧
      </h2>
      <span class="section-sub">毎朝自動収集 × {SUPERVISOR_LABEL}</span>
    </div>
    <div class="article-list">
      {articles.map((article, index) => (
        <>
          {/* フィード内広告: 5記事目の後に挿入 */}
          {index === 5 && <AdUnit name="feedInline" />}
          <article class="article-card">
            <div class="article-meta">
              <time class="article-date">{article.data.date}</time>
              <span class="cpa-badge">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 13c0 5-3.5 7.5-8 8.5-4.5-1-8-3.5-8-8.5V6l8-3 8 3z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
                {SUPERVISOR_LABEL}
              </span>
              <span class="read-time">約3分</span>
            </div>
            <h3 class="article-title">
              <a href={`/daily/${article.slug}`}>{article.data.title}</a>
            </h3>
            <p class="article-summary">{article.data.summary}</p>
            <div class="article-footer">
              <div class="article-tags">
                {article.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <a href={`/daily/${article.slug}`} class="read-more" aria-label={`${article.data.title}を読む`}>
                続きを読む
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </a>
            </div>
          </article>
        </>
      ))}
    </div>
  </section>

  <!-- 広告: 週刊セクション上ディスプレイ広告 -->
  <AdUnit name="homepageDisplay" />

  <!-- 週刊ダイジェスト: SEO資産化コンテンツ -->
  {weeklyArticles.length > 0 && (
    <section class="weekly-section">
      <div class="section-header">
        <h2>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          週刊AI会計ダイジェスト
        </h2>
        <span class="section-sub">毎週月曜更新</span>
      </div>
      <div class="weekly-grid">
        {weeklyArticles.map((article) => (
          <article class="weekly-card">
            <time class="weekly-date">{article.data.weekStart} 〜 {article.data.weekEnd}</time>
            <h3 class="weekly-title">
              <a href={`/weekly/${article.slug}`}>{article.data.title}</a>
            </h3>
            <p class="weekly-summary">{article.data.summary}</p>
          </article>
        ))}
      </div>
      <div class="weekly-footer">
        <a href="/weekly" class="btn btn-outline">全てのダイジェストを見る</a>
      </div>
    </section>
  )}

  <!-- AI活用Tips: 若手会計士・税理士スタッフ向け -->
  {tips.length > 0 && (
    <section class="tips-section">
      <div class="section-header">
        <h2>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
          AI活用Tips
        </h2>
        <span class="section-sub">若手会計士・税理士スタッフ向け</span>
      </div>
      <div class="tips-grid">
        {tips.map((tip) => (
          <article class="tip-card">
            <time class="tip-date">{tip.data.date}</time>
            <h3 class="tip-title">
              <a href={`/tips/${tip.slug}`}>{tip.data.title}</a>
            </h3>
            <p class="tip-summary">{tip.data.summary}</p>
            {tip.data.tool && (
              <span class="tool-badge">{tip.data.tool}</span>
            )}
          </article>
        ))}
      </div>
      <div class="tips-footer">
        <a href="/tips" class="btn btn-outline">全てのTipsを見る</a>
        <a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener" class="btn btn-outline">
          経理AIプロンプト集 (BOOTH)
        </a>
      </div>
    </section>
  )}

  <!-- CTA: ペルソナ別に分けた訴求 -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="cta-inner">
      <h2 id="cta-heading">会計×AIを武器にする</h2>
      <p>
        毎朝7時にX(@KaikeiAI_Lab)でニュース速報配信中。<br />
        実務で使えるAIプロンプト集はBOOTHで配布中（無料サンプルあり）。
      </p>
      <div class="cta-links">
        <a href="https://x.com/KaikeiAI_Lab" target="_blank" rel="noopener" class="btn btn-primary">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X でフォロー
        </a>
        <a href="https://ezark-devtools.booth.pm/" target="_blank" rel="noopener" class="btn btn-outline">
          AIプロンプト集 (BOOTH)
        </a>
        <a href="https://note.com/ezark_company" target="_blank" rel="noopener" class="btn btn-outline">
          週刊レポート (note)
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ==========================================
     Hero -- 経理プロ向けポジショニング
  ========================================== */
  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
  }

  .hero-eyebrow {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
