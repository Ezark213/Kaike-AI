---
/**
 * Newsletter signup CTA component.
 * Uses Buttondown embed-subscribe API (no-cors fetch to avoid CAPTCHA redirect).
 * Props:
 *   variant: 'full' (homepage, with heading) | 'compact' (article bottom)
 */
interface Props {
  variant?: 'full' | 'compact'
}

const { variant = 'full' } = Astro.props
const id = `nl-${Math.random().toString(36).slice(2, 8)}`
---

<section class:list={['newsletter-cta', `newsletter-cta--${variant}`]} aria-labelledby={`${id}-heading`}>
  <div class="newsletter-cta-inner">
    {variant === 'full' ? (
      <h2 id={`${id}-heading`} class="newsletter-cta-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        毎週のAI会計ニュースまとめをメールで受け取る
      </h2>
    ) : (
      <h3 id={`${id}-heading`} class="newsletter-cta-title">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        毎週のAI会計ニュースまとめをメールで受け取る
      </h3>
    )}
    <p class="newsletter-cta-desc">
      週1回、AI×会計の重要ニュースを厳選してお届け。CPA試験合格者が「実務への影響」を解説します。
    </p>
    <form class={`newsletter-cta-form`} data-nl-form>
      <input
        type="email"
        name="email"
        placeholder="メールアドレスを入力..."
        required
        aria-label="メールアドレス"
        data-nl-email
      />
      <button type="submit" class="btn btn-primary" data-nl-btn>
        無料で購読
      </button>
    </form>
    <p class="newsletter-cta-note" data-nl-status>無料・週1回配信・いつでも解除可能</p>
  </div>
</section>

<script is:inline>
  (function() {
    document.querySelectorAll('[data-nl-form]').forEach(function(form) {
      if (form.dataset.nlInit) return;
      form.dataset.nlInit = '1';
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var email = form.querySelector('[data-nl-email]').value;
        var btn = form.querySelector('[data-nl-btn]');
        var status = form.closest('.newsletter-cta').querySelector('[data-nl-status]');
        if (!email) return;
        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.style.pointerEvents = 'none';
        btn.textContent = '送信中...';
        var formData = new FormData();
        formData.append('email', email);
        fetch('https://buttondown.com/api/emails/embed-subscribe/kaikei-ai-daily', {
          method: 'POST',
          body: formData,
          mode: 'no-cors'
        })
        .then(function() {
          status.textContent = '登録リクエストを送信しました。確認メールをご確認ください。';
          status.style.color = '#16a34a';
          form.reset();
          if (typeof gtag === 'function') {
            gtag('event', 'newsletter_signup', { method: 'buttondown', email_domain: email.split('@')[1] || '' });
          }
        })
        .catch(function() {
          window.open('https://buttondown.com/kaikei-ai-daily', '_blank');
          status.textContent = '別ウィンドウで登録ページを開きました。';
          status.style.color = '#0066cc';
        })
        .finally(function() {
          btn.disabled = false;
          btn.style.opacity = '';
          btn.style.pointerEvents = '';
          btn.textContent = '無料で購読';
        });
      });
    });
  })();
</script>

<style>
  /* ── Newsletter CTA shared ── */
  .newsletter-cta {
    border: 4px solid var(--color-outline);
    box-shadow: 6px 6px 0 var(--color-shadow);
    background: var(--color-surface);
    text-align: center;
  }

  .newsletter-cta--full {
    padding: 2rem;
    margin: 2rem 0;
  }

  .newsletter-cta--compact {
    padding: 1.5rem;
    margin: 2rem 0 1.5rem;
  }

  .newsletter-cta-title {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--color-on-surface);
  }

  .newsletter-cta--full .newsletter-cta-title {
    font-size: 1.25rem;
  }

  .newsletter-cta--compact .newsletter-cta-title {
    font-size: 1.0625rem;
  }

  .newsletter-cta-desc {
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .newsletter-cta-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter-cta-form input[type="email"] {
    flex: 1;
    padding: 0.625rem 0.875rem;
    border: 3px solid var(--color-outline);
    font-size: 0.875rem;
    font-family: var(--font-sans);
    background: var(--color-background, var(--color-bg));
    color: var(--color-on-surface);
    min-height: 44px;
  }

  .newsletter-cta-form input[type="email"]:focus {
    outline: 3px solid var(--color-primary);
    outline-offset: -3px;
  }

  .newsletter-cta-note {
    font-size: 0.75rem !important;
    color: var(--color-on-surface-variant) !important;
    margin-top: 0.5rem;
    margin-bottom: 0 !important;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    border: 3px solid var(--color-outline);
    box-shadow: 4px 4px 0 var(--color-outline);
    transition: transform 0.15s, box-shadow 0.15s;
    cursor: pointer;
    min-height: 44px;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }

  .btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--color-outline);
  }

  .btn:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .newsletter-cta-form { flex-direction: column; }
    .newsletter-cta-title { font-size: 1rem !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn { transition: none; }
  }
</style>
